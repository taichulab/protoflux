# ==============================
# protoflux server
# ==============================
PROTOFLUX_HOST=0.0.0.0
PROTOFLUX_PORT=8080

# Optional routes by model prefix, first match wins.
# Example:
# PROTOFLUX_ROUTING_RULES=[{"match":"claude-","upstream":"dashscope_1"}]
PROTOFLUX_ROUTING_RULES=

# REQUIRED: URI-style model/upstream mapping (no JSON compatibility fallback)
# Supports two forms:
# 1) token auth
#    protocol://[publish-model]/[upstream-model]/[base_url]/[api-key]/[plugin1|plugin2..]
# 2) ak/sk auth
#    protocol://[publish-model]/[upstream-model]/[base_url]/["region":"ak":"sk"]/[plugin1|plugin2..]
#
# publish-model: 对外 API 暴露的模型名
# upstream-model: 转发到上游的模型名
# plugins: 可选，不配置表示无插件
# built-in plugin:
# - xml_toolcall
#
# ==========================================
# Option A: Multi-line Style (Recommended for Local/Docker)
# ==========================================
# PROTOFLUX_MODEL_URIS=dashscope://[claude-3-5-sonnet]/[qwen-max]/[https://dashscope.aliyuncs.com/api/v1]/[sk-xxxxxxx]/[xml_toolcall]
# PROTOFLUX_MODEL_URIS=openai_compat://[gpt-4o]/[gpt-4o]/[https://api.openai.com/v1]/[sk-xxxxxxx]

# ==========================================
# Option B: Single-line Style (Required for AWS/ECS/Lambda)
# ==========================================
# entries can be separated by ";" or ","
# PROTOFLUX_MODEL_URIS=dashscope://[claude-3-5-sonnet]/[qwen-max]/[https://dashscope.aliyuncs.com/api/v1]/[sk-xxx]/[xml_toolcall];openai_compat://[gpt-4o]/[gpt-4o]/[https://api.openai.com/v1]/[sk-xxx];bedrock://[zai.glm-5]/[zai.glm-5]/[us-east-1]/["us-east-1":"AKIAxxxx":"SKxxxx"]/[xml_toolcall]

PROTOFLUX_MODEL_URIS=


